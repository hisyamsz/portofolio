---
import type { SkillCategoryType } from '../../data/skills';
import SkillBadge from './SkillBadge.astro';
import { Monitor, Database, Settings } from '@lucide/astro';

interface Props {
  category: SkillCategoryType;
  className?: string;
}

const { category, className = '' } = Astro.props;

// Render correct icon based on iconName
---

<div
  class={`bg-white p-8 rounded-3xl border border-slate-100 shadow-sm hover:shadow-xl transition-all duration-300 hover:-translate-y-1.5 flex flex-col justify-between min-h-[400px] group ${className}`}
>
  <div>
    <div class="mb-6 flex items-center gap-4">
      <div
        class="inline-flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl bg-linear-to-br from-amber-500 to-orange-500 text-white shadow-lg shadow-orange-500/20"
      >
        {category.iconName === 'Monitor' && <Monitor class="h-7 w-7" />}
        {category.iconName === 'Database' && <Database class="h-7 w-7" />}
        {category.iconName === 'Settings' && <Settings class="h-7 w-7" />}
      </div>
      <h3 class="text-dark text-xl leading-tight font-extrabold">
        {category.title}
      </h3>
    </div>
    <p class="text-secondary mb-6 text-sm leading-relaxed">
      {category.description}
    </p>
  </div>
  <div class="mt-auto flex flex-wrap gap-2">
    {category.skills.map((skill) => <SkillBadge skill={skill} />)}
  </div>
</div>
