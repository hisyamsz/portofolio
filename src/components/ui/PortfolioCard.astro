---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  title: string;
  image: ImageMetadata;
  link: string;
  category: string;
}
const { title, image, link, category } = Astro.props;
---

<div
  class="group portfolio-card-el flex h-full w-full flex-col rounded-3xl border border-slate-100 bg-white p-6 shadow-sm transition-all duration-300 hover:shadow-xl"
  data-category={category}
>
  <a
    href={link}
    target="_blank"
    title={title}
    class="relative mb-5 block shrink-0 overflow-hidden rounded-2xl bg-slate-200"
  >
    <Image
      src={image}
      alt={title}
      class="h-48 w-full transform object-cover object-top transition-all duration-500 group-hover:scale-110"
    />
  </a>
  <div class="flex grow flex-col">
    <a
      href={link}
      target="_blank"
      class="text-dark mb-3 flex items-center text-2xl font-bold transition-colors duration-300 group-hover:text-amber-700"
    >
      {title}
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="ml-2 h-6 w-6 -translate-x-4 opacity-0 transition-all duration-300 group-hover:translate-x-0 group-hover:opacity-100"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
      </svg>
    </a>
    <div class="text-secondary mb-4 text-base leading-relaxed">
      <slot />
    </div>
  </div>
</div>
